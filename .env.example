# Google Analytics 4 Measurement ID (格式: G-XXXXXXXXXX)
# 获取地址: https://analytics.google.com/ → 管理 → 数据流 → 衡量 ID
VITE_GA4_ID=

# Microsoft Clarity Project ID
# 获取地址: https://clarity.microsoft.com/ → 新建项目 → 获取 Project ID
VITE_CLARITY_ID=

# Vercel Analytics (通过 Vercel Dashboard 启用，无需代码配置)
# Vercel Dashboard → Project → Analytics → Enable
